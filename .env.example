# ============================================================
# WordPress Stack — Environment Variables
# Copy this file to .env and fill in secure values.
# NEVER commit .env with real passwords to version control.
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wp_blog
MYSQL_USER=wp_blog
MYSQL_PASSWORD=change_me_wp

# --- WordPress ---
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_USER=wp_blog
WORDPRESS_DB_PASSWORD=change_me_wp
WORDPRESS_DB_NAME=wp_blog

# --- Ports ---
WP_PORT=8080
ADMINER_PORT=8081
